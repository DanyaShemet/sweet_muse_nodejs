# Середовище (development, production, test)
NODE_ENV=development

# База даних
MONGODB_URI=mongodb://localhost:27017/taxonomy-generator

# JWT
JWT_SECRET=your-super-secret-jwt-key-here

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Адмін логін (для простоти)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Фронтенд URL
FRONTEND_URL=http://localhost:5173

# Порт сервера
PORT=3000

# Email Configuration
# Option 1: Brevo (recommended for Render - 300 emails/day free forever)
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USER=your-brevo-login@email.com
BREVO_API_TOKEN=your-brevo-smtp-key
EMAIL_FROM=verified-sender@yourdomain.com

# Option 2: Gmail with App Password (if not using Brevo)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password-here
# EMAIL_FROM=your-email@gmail.com